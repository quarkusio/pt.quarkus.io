#. type: Title =
#: _versions/main/guides/hibernate-reactive.adoc
#, fuzzy
msgid "Configuration Reference for Hibernate Reactive"
msgstr "Referência de configuração para o Hibernate Reactive"

#. type: Plain text
#: _versions/main/guides/hibernate-reactive.adoc
#, fuzzy
msgid ""
"You will notice that some properties\n"
