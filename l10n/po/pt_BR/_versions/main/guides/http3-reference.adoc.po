msgstr "Alt-Svc: h3=\":8443\"; ma=86400"

#. type: Plain text
#. mt: deepl
#: _versions/main/guides/http3-reference.adoc
#, fuzzy
msgid ""
"This tells clients that HTTP/3 is available on the same port.\n"
"Browsers and HTTP clients that support HTTP/3 will upgrade to QUIC for subsequent requests."
msgstr "Isso informa aos clientes que o HTTP/3 está disponível na mesma porta. Os navegadores e clientes HTTP compatíveis com o HTTP/3 passarão a utilizar o QUIC para as solicitações subsequentes."

#. type: Plain text
#. mt: deepl
#: _versions/main/guides/http3-reference.adoc
#, fuzzy
