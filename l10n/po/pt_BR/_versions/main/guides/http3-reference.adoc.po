#. type: Title =
#. mt: deepl
#: _versions/main/guides/http3-reference.adoc
#, fuzzy
msgid "Limitations"
msgstr "Limitações"

#. type: Plain text
#. mt: deepl
#: _versions/main/guides/http3-reference.adoc
#, fuzzy
msgid "**Experimental** — This feature is under active development. APIs and behavior may change."
msgstr "*Experimental* — Este recurso está em desenvolvimento ativo. As APIs e o comportamento podem sofrer alterações."

#. type: Plain text
#. mt: deepl
#: _versions/main/guides/http3-reference.adoc
#, fuzzy
msgid "**UDP in containers** — HTTP/3 uses UDP. If your application runs in a container (Docker, Kubernetes), ensure UDP port forwarding is configured for the HTTPS port. Some corporate firewalls may also block UDP traffic."
msgstr "*UDP em contêineres* — O HTTP/3 utiliza o protocolo UDP. Caso sua aplicação seja executada em um contêiner (Docker, Kubernetes), certifique-se de que o encaminhamento de porta UDP esteja configurado para a porta HTTPS. Alguns firewalls corporativos também podem bloquear o tráfego UDP."

#. type: Plain text
#. mt: deepl
#: _versions/main/guides/http3-reference.adoc
#, fuzzy
msgid "**No WebSocket over HTTP/3** — WebSocket connections use HTTP/1.1 or HTTP/2. This is a Vert.x limitation, not specific to Quarkus."
msgstr "*Não há WebSocket sobre HTTP/3* — as conexões WebSocket utilizam HTTP/1.1 ou HTTP/2. Trata-se de uma limitação do Vert.x, não específica do Quarkus."

#. type: Plain text
#. mt: deepl
