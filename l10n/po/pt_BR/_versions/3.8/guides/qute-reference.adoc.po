#. type: Title ==
#: _versions/3.8/guides/qute-reference.adoc
msgid "Expressions"
msgstr "ExpressĂµes"

#. type: Plain text
#: _versions/3.8/guides/qute-reference.adoc
#, fuzzy
msgid ""
"An <<expressions,expression>> outputs an evaluated value.\n"
"It consists of one or more parts.\n"
