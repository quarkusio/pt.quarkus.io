#. mt: deepl
#: _versions/3.34/guides/config-reference.adoc
#, fuzzy
msgid ""
"System properties can be handed to the application through the `-D` flag during startup. The following examples assign\n"
"the value `youshallnotpass` to the attribute `quarkus.datasource.password`."
msgstr "As propriedades do sistema podem ser passadas ao aplicativo por meio do sinalizador `-D` durante a inicialização. Os exemplos a seguir atribuem o valor `“youshallnotpass”` ao atributo `quarkus.datasource.password` ."

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/config-reference.adoc
#, fuzzy
msgid "For Quarkus dev mode: `./mvnw quarkus:dev -Dquarkus.datasource.password=youshallnotpass`"
msgstr "Para o modo de desenvolvimento do Quarkus: `./mvnw quarkus:dev -Dquarkus.datasource.password=youshallnotpass`"

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/config-reference.adoc
#, fuzzy
msgid "For a runner jar: `java -Dquarkus.datasource.password=youshallnotpass -jar target/quarkus-app/quarkus-run.jar`"
msgstr "Para executar o arquivo JAR: `java -Dquarkus.datasource.password=youshallnotpass -jar target/quarkus-app/quarkus-run.jar`"

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/config-reference.adoc
#, fuzzy
msgid "For a native executable: `./target/myapp-runner -Dquarkus.datasource.password=youshallnotpass`"
msgstr "Para um executável nativo: `./target/myapp-runner -Dquarkus.datasource.password=youshallnotpass`"

