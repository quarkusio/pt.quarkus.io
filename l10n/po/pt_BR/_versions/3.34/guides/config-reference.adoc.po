#. mt: deepl
#: _versions/3.34/guides/config-reference.adoc
#, fuzzy
msgid "By default, Quarkus reads configuration properties from multiple sources (by descending ordinal):"
msgstr "Por padrão, o Quarkus lê as propriedades de configuração a partir de várias fontes (em ordem decrescente):"

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/config-reference.adoc
#, fuzzy
msgid "(400) <<system-properties,System properties>>"
msgstr "(400) xref:system-properties[Propriedades do sistema]"

