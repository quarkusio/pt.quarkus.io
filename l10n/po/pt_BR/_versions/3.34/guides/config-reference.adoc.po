#. mt: deepl
#: _versions/3.34/guides/config-reference.adoc
#, fuzzy
msgid "(300) <<environment-variables,Environment variables>>"
msgstr "(300) xref:environment-variables[Variáveis de ambiente]"

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/config-reference.adoc
#, fuzzy
msgid "(295) <<env-file,.env>> file in the current working directory"
msgstr "(295) Arquivo xref:env-file[.env] no diretório de trabalho atual"

#. type: Plain text
