msgid "`smallrye.jwt.expiration.grace`"
msgstr "`smallrye.jwt.expiration.grace`"

#. type: Table
#. mt: deepl
#: _versions/3.34/guides/security-jwt.adoc
#, fuzzy
msgid "0"
msgstr "0"

