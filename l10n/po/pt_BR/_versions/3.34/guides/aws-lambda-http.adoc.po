msgstr "Para ativar esse recurso de segurança, adicione o seguinte ao seu arquivo `application.properties` :"

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/aws-lambda-http.adoc
#, fuzzy
msgid "quarkus.lambda-http.enable-security=true"
msgstr "quarkus.lambda-http.enable-security=true"

