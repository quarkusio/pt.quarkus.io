msgstr "Mesmo com toda a infraestrutura de rastreamento já instalada, o rastreamento da fonte de dados não está habilitado por padrão, e é necessário habilitá-lo definindo esta propriedade:"

#. type: Title ==
#. mt: deepl
#: _versions/3.34/guides/datasource.adoc
#, fuzzy
msgid "Narayana transaction manager integration"
msgstr "Integração do gerenciador de transações Narayana"

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/datasource.adoc
#, fuzzy
msgid "Integration is automatic if the Narayana JTA extension is also available."
msgstr "A integração ocorre automaticamente caso a extensão Narayana JTA também esteja disponível."

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/datasource.adoc
#, fuzzy
