#: _versions/3.34/guides/extension-registry-user.adoc
#, fuzzy
msgid "Enabling the debug mode"
msgstr "Ativando o modo de depuração"

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/extension-registry-user.adoc
