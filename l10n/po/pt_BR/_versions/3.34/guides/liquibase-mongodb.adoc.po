#, fuzzy
msgid "Using Liquibase MongoDB"
msgstr "Utilização do Liquibase com o MongoDB"

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/liquibase-mongodb.adoc
#, fuzzy
msgid ""
"https://www.liquibase.org/[Liquibase] is an open source tool for database schema change management,\n"
"it allows managing MongoDB databases via it's https://github.com/liquibase/liquibase-mongodb[MongoDB Extension]."
msgstr "link:https://www.liquibase.org/[O Liquibase] é uma ferramenta de código aberto para gerenciamento de alterações no esquema de bancos de dados; permite gerenciar bancos de dados MongoDB por meio de sua link:https://github.com/liquibase/liquibase-mongodb[extensão para MongoDB] ."

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/liquibase-mongodb.adoc
#, fuzzy
msgid "Quarkus provides first class support for using Liquibase MongoDB Extension as will be explained in this guide."
msgstr "O Quarkus oferece suporte de primeira classe para o uso da extensão Liquibase para MongoDB, conforme será explicado neste guia."

