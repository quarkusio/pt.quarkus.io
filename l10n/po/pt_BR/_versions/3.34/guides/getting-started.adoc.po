msgstr "`/q/métricas`"

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/getting-started.adoc
#, fuzzy
msgid "`/q/openapi`"
msgstr "`/q/openapi`"

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/getting-started.adoc
#, fuzzy
msgid "`/q/info`"
msgstr "`/q/info`"

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/getting-started.adoc
#, fuzzy
msgid "but users can also choose to expose one that might present a security risk under a different TCP port using a dedicated xref:management-interface-reference.adoc[management interface]."
