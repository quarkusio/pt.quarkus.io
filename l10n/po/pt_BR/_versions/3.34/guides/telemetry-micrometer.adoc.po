#. mt: deepl
#: _versions/3.34/guides/telemetry-micrometer.adoc
#, fuzzy
msgid "`allocator.pooled.arenas`"
msgstr "`alocador.pooled.arenas`"

#. type: Table
#. mt: deepl
#: _versions/3.34/guides/telemetry-micrometer.adoc
#, fuzzy
msgid "Number of arenas handling memory allocation"
msgstr "Número de arenas responsáveis pela alocação de memória"

