msgid "Inspecting the Generated/Transformed Classes"
msgstr "Inspeção das classes geradas/transformadas"

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/writing-extensions.adoc
#, fuzzy
msgid ""
