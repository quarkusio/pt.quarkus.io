#. type: Title ==
#. mt: deepl
#: _versions/3.34/guides/kubernetes-client.adoc
#, fuzzy
msgid "Customizing and overriding"
msgstr "Personalização e substituição"

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/kubernetes-client.adoc
#, fuzzy
msgid "Quarkus provides multiple integration points for influencing the Kubernetes Client provided as a CDI bean."
msgstr "O Quarkus oferece vários pontos de integração para interagir com o cliente do Kubernetes, fornecido como um bean CDI."

#. type: Title ===
#. mt: deepl
#: _versions/3.34/guides/kubernetes-client.adoc
#, fuzzy
msgid "Kubernetes Client Config customization"
msgstr "Personalização da configuração do cliente do Kubernetes"

#. type: Plain text
