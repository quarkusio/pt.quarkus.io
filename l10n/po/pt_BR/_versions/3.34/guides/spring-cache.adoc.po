#. mt: deepl
#: _versions/3.34/guides/spring-cache.adoc
#, fuzzy
msgid "Quarkus Extension for Spring Cache API"
msgstr "Extensão do Quarkus para a API do Spring Cache"

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/spring-cache.adoc
#, fuzzy
msgid "While users are encouraged to use xref:cache.adoc[Quarkus annotations for caching], Quarkus nevertheless provides a compatibility layer for Spring Cache annotations in the form of the `spring-cache` extension."
msgstr "Embora os usuários sejam incentivados a utilizar xref:cache.adoc[as anotações do Quarkus para o armazenamento em cache] , o Quarkus oferece, no entanto, uma camada de compatibilidade para as anotações do Spring Cache por meio da extensão `spring-cache` ."

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/spring-cache.adoc
#, fuzzy
msgid "This guide explains how a Quarkus application can leverage the well known Spring Cache annotations to enable application data caching for their Spring beans."
msgstr "Este guia explica como um aplicativo Quarkus pode utilizar as conhecidas anotações do Spring Cache para habilitar o armazenamento em cache dos dados do aplicativo para seus beans do Spring."

