msgstr "Faça o logout local apagando o cookie de sessão."

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/security-oidc-code-flow-authentication.adoc
#, fuzzy
msgid "Revoke the authorization code flow access token."
msgstr "Revogar o token de acesso do fluxo de código de autorização."

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/security-oidc-code-flow-authentication.adoc
#, fuzzy
