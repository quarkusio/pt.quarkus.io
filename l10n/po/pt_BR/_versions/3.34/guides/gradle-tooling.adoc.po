#, fuzzy
msgid "Notes"
msgstr "Notas"

#. type: Table
#. mt: deepl
#: _versions/3.34/guides/gradle-tooling.adoc
#, fuzzy
msgid "Caching (non-CI)"
msgstr "Armazenamento em cache (não CI)"

#. type: Table
#. mt: deepl
