#. mt: deepl
#: _versions/3.34/guides/jfr.adoc
#, fuzzy
msgid "HTTP Method"
msgstr "Método HTTP"

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/jfr.adoc
#, fuzzy
msgid "URI"
msgstr "URI"

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/jfr.adoc
#, fuzzy
