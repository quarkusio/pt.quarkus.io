msgstr "Registra o intervalo de tempo desde o início do processo do servidor REST até o fim do processo do servidor REST."

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/jfr.adoc
#, fuzzy
msgid "RestStart"
msgstr "RestStart"

#. type: Plain text
#. mt: deepl
