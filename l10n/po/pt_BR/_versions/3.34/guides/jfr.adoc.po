msgstr "Registra informações sobre a execução do Quarkus. Este evento inclui a versão do Quarkus, seus perfis e o modo em que está sendo executado."

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/jfr.adoc
#, fuzzy
msgid "QuarkusApplication"
msgstr "QuarkusApplication"

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/jfr.adoc
#, fuzzy
msgid "Records information about Quarkus application running. This event includes the name of the application and its version."
msgstr "Registra informações sobre a execução de um aplicativo Quarkus. Este evento inclui o nome do aplicativo e sua versão."

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/jfr.adoc
#, fuzzy
msgid "Extension"
msgstr "Extensão"

#. type: Plain text
#. mt: deepl
#: _versions/3.34/guides/jfr.adoc
#, fuzzy
msgid "Records information about extensions included in the running Quarkus. This event includes the name of the extensions installed in Quarkus."
msgstr "Registra informações sobre as extensões incluídas no Quarkus em execução. Este evento inclui o nome das extensões instaladas no Quarkus."

#. type: Title ==
