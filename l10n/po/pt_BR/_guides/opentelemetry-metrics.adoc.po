#. type: YAML Front Matter: title
#. mt: gemini
#: _guides/opentelemetry-metrics.adoc
#, fuzzy
msgid "Using OpenTelemetry Metrics"
msgstr "Usando o OpenTelemetry Metrics"

#. type: Plain text
#. mt: deepl
#: _guides/opentelemetry-metrics.adoc
msgid "<a class=\"status-label status-preview\" title=\"This extension's backward compatibility and presence in the ecosystem is not guaranteed\" href=\"#extension-status-note\">preview</a>"
msgstr "<a class=\"status-label status-preview\" title=\"A compatibilidade com versões anteriores e a presença desta extensão no ecossistema não são garantidas\" href=\"#extension-status-note\">preview</a>"

#. type: Plain text
#. mt: gemini
#: _guides/opentelemetry-metrics.adoc
#, fuzzy
msgid ""
"This guide explains how your Quarkus application can utilize https://opentelemetry.io/[OpenTelemetry] (OTel) to provide\n"
"metrics for interactive web applications."
msgstr "Este guia explica como sua aplicação Quarkus pode utilizar o https://opentelemetry.io/[OpenTelemetry] (OTel) para fornecer métricas para aplicações web interativas."

#. type: Plain text
#. mt: gemini
#: _guides/opentelemetry-metrics.adoc
#, fuzzy
msgid "This document is part of the xref:observability.adoc[Observability in Quarkus reference guide] which features this and other observability related components."
msgstr "Este documento faz parte do xref:observability.adoc[guia de referência de Observabilidade no Quarkus], que apresenta este e outros componentes relacionados à observabilidade."

#. type: Plain text
#. mt: gemini
#: _guides/opentelemetry-metrics.adoc
#, fuzzy
msgid "OpenTelemetry Metrics is considered _tech preview_ and is disabled by default."
msgstr "O OpenTelemetry Metrics é considerado _tech preview_ e está desabilitado por padrão."

#. type: Plain text
#. mt: gemini
#: _guides/opentelemetry-metrics.adoc
#, fuzzy
msgid "Automatic metrics instrumentation in Quarkus is handled by xref:telemetry-micrometer.adoc[Micrometer] and the xref:telemetry-micrometer-to-opentelemetry.adoc[quarkus-micrometer-opentelemetry] extension bridges those metrics into OpenTelemetry."
msgstr "A instrumentação automática de métricas no Quarkus é gerenciada pelo xref:telemetry-micrometer.adoc[Micrometer] e a extensão xref:telemetry-micrometer-to-opentelemetry.adoc[quarkus-micrometer-opentelemetry] faz a ponte dessas métricas para o OpenTelemetry."

#. type: Plain text
#. mt: gemini
#: _guides/opentelemetry-metrics.adoc
#, fuzzy
msgid "The xref:opentelemetry.adoc[OpenTelemetry Guide] is available with signal independent information about the OpenTelemetry extension."
msgstr "O xref:opentelemetry.adoc[Guia do OpenTelemetry] está disponível com informações independentes de sinal sobre a extensão OpenTelemetry."

#. type: Plain text
#. mt: gemini
#: _guides/opentelemetry-metrics.adoc
#, fuzzy
msgid "If you search more information about OpenTelemetry Tracing, please refer to the xref:opentelemetry-tracing.adoc[OpenTelemetry Tracing Guide]."
msgstr "Se você procurar mais informações sobre o OpenTelemetry Tracing, consulte o xref:opentelemetry-tracing.adoc[Guia do OpenTelemetry Tracing]."

