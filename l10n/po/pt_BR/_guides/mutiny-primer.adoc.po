#: _guides/mutiny-primer.adoc
#, fuzzy, no-wrap
msgid "Subscription (1), Item (0..1), failure (0..1)"
msgstr "Subscription (1), Item (0..1), falha (0..1)"

#. type: Table
#. mt: gemini
#: _guides/mutiny-primer.adoc
#, fuzzy, no-wrap
msgid "Cancellation"
msgstr "Cancelamento"

#. type: Table
#. mt: gemini
#: _guides/mutiny-primer.adoc
#, fuzzy, no-wrap
msgid "Multi"
msgstr "Multi"

#. type: Table
#. mt: gemini
#: _guides/mutiny-primer.adoc
#, fuzzy, no-wrap
msgid "Subscription (1), Item (0..n), failure (0..1), completion (0..1)"
msgstr "Subscription (1), Item (0..n), falha (0..1), conclusão (0..1)"

#. type: Table
#. mt: gemini
#: _guides/mutiny-primer.adoc
#, fuzzy, no-wrap
