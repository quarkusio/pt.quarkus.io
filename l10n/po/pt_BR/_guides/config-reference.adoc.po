msgstr "Propriedades do Sistema"

#. type: Plain text
#. mt: gemini
#: _guides/config-reference.adoc
#, fuzzy
msgid "Environment Variables"
msgstr "Variáveis de Ambiente"

#. type: Plain text
#. mt: gemini
#: _guides/config-reference.adoc
#, fuzzy
msgid "`.env`"
msgstr "`.env`"

#. type: Plain text
