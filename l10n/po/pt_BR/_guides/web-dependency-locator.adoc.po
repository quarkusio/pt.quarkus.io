#: _guides/web-dependency-locator.adoc
#, fuzzy
msgid "Web dependency locator"
msgstr "Localizador de dependências web"

#. type: Plain text
#. mt: gemini
#: _guides/web-dependency-locator.adoc
#, fuzzy
msgid "This document shows how static resources can be served from web dependency jars like https://www.webjars.org[WebJars] and https://mvnpm.org[mvnpm]."
msgstr "Este documento mostra como recursos estáticos podem ser servidos a partir de jars de dependência web como https://www.webjars.org[WebJars] e https://mvnpm.org[mvnpm]."

#. type: Title =
#. mt: gemini
#: _guides/web-dependency-locator.adoc
#, fuzzy
msgid "Using the `{web-locator-ga}` extension"
msgstr "Usando a extensão `{web-locator-ga}`"

#. type: Block title
