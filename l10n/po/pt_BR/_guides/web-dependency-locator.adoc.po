msgstr "build.gradle"

#. type: Title ==
#. mt: gemini
#: _guides/web-dependency-locator.adoc
#, fuzzy
msgid "WebJars"
msgstr "WebJars"

#. type: Plain text
#. mt: gemini
#: _guides/web-dependency-locator.adoc
#, fuzzy
msgid "If you are using https://www.webjars.org[WebJars], like the following JQuery one:"
msgstr "Se você estiver usando https://www.webjars.org[WebJars], como este do JQuery:"

#. type: Plain text
#. mt: gemini
#: _guides/web-dependency-locator.adoc
#, fuzzy
msgid "you can reference the files in the jar from your HTML, example `/webjars/jquery/3.1.1/jquery.min.js`."
msgstr "você pode referenciar os arquivos no jar a partir do seu HTML, por exemplo `/webjars/jquery/3.1.1/jquery.min.js`."

#. type: Plain text
#. mt: gemini
#: _guides/web-dependency-locator.adoc
#, fuzzy
msgid "The above is available by default, however, adding the `{web-locator-ga}` extension allows you to reference the files without having to include the version in the path, example `/webjars/jquery/jquery.min.js`."
msgstr "O exemplo acima está disponível por padrão, no entanto, adicionar a extensão `{web-locator-ga}` permite que você referencie os arquivos sem ter que incluir a versão no caminho, por exemplo `/webjars/jquery/jquery.min.js`."

