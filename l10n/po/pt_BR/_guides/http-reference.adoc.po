#: _guides/http-reference.adoc
#, fuzzy
msgid "_Note: To remain compatible with earlier versions of Quarkus (before 0.16) the default password is set to \"password\". It is therefore not a mandatory parameter!_"
msgstr "_Nota: Para permanecer compatível com versões anteriores do Quarkus (anteriores à 0.16), a senha padrão é definida como \"password\". Portanto, não é um parâmetro obrigatório!_"

#. type: Title ==
#. mt: gemini
#: _guides/http-reference.adoc
#, fuzzy, no-wrap
msgid "Configure the HTTPS port"
msgstr "Configurar a porta HTTPS"

#. type: Plain text
#. mt: gemini
#: _guides/http-reference.adoc
#, fuzzy
msgid "By default, Quarkus listens to port 8443 for SSL secured connections and 8444 when running tests."
msgstr "Por padrão, o Quarkus escuta na porta 8443 para conexões seguras por SSL e 8444 ao executar testes."

#. type: Plain text
#. mt: gemini
