msgstr "Agora, ao executar a aplicação, você verá o Quarkus iniciando."

#. type: Plain text
#. mt: gemini
#: _guides/scripting.adoc
#, fuzzy
msgid "Use: `jbang quarkusapp.java`:"
msgstr "Use: `jbang quarkusapp.java`:"

#. type: Plain text
#: _guides/scripting.adoc
