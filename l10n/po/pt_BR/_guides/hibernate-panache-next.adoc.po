msgstr "pom.xml"

#. type: Block title
#: _guides/hibernate-panache-next.adoc
msgid "build.gradle"
msgstr "build.gradle"

#. type: Plain text
#. mt: gemini
#: _guides/hibernate-panache-next.adoc
#, fuzzy
msgid "You also have to configure the Hibernate processor, which is required:"
msgstr "Você também deve configurar o processador Hibernate, o que é obrigatório:"

#. type: Plain text
#. mt: gemini
#: _guides/hibernate-panache-next.adoc
#, fuzzy
msgid "You can use any of the xref:hibernate-orm.adoc#setting-up-and-configuring-hibernate-orm[supported JDBC drivers]."
msgstr "Você pode usar qualquer um dos xref:hibernate-orm.adoc#setting-up-and-configuring-hibernate-orm[drivers JDBC suportados]."

#. type: Plain text
