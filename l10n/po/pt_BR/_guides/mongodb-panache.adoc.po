msgstr "`lastname is not null` será mapeado para `{'lastname':{'$exists': true}}`"

#. type: Plain text
#. mt: gemini
#: _guides/mongodb-panache.adoc
#, fuzzy
msgid "`status in ?1` will be mapped to `{'status':{$in: ?1}}`"
msgstr "`status in ?1` será mapeado para `{'status':{$in: ?1}}`"

#. type: Plain text
#. mt: gemini
#: _guides/mongodb-panache.adoc
#, fuzzy
msgid ""
