#. mt: gemini
#: _guides/extension-registry-user.adoc
#, fuzzy
msgid "QUARKUS_REGISTRY_<UPPERCASED_AND_UNDERSCORED_REGISTRY_ID>_"
msgstr "QUARKUS_REGISTRY_<UPPERCASED_AND_UNDERSCORED_REGISTRY_ID>_"

