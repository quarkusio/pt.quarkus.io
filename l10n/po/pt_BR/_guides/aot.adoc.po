#: _guides/aot.adoc
#, fuzzy
msgid "AppCDS limitations"
msgstr "Limitações do AppCDS"

#. type: Plain text
#. mt: gemini
#: _guides/aot.adoc
#, fuzzy
msgid "The paths to the JAR and archive must match exactly between build and runtime"
msgstr "Os caminhos para o JAR e o arquivo devem corresponder exatamente entre a compilação e o tempo de execução"

#. type: Plain text
#. mt: gemini
#: _guides/aot.adoc
#, fuzzy
msgid "The JDK version must be **exactly** the same"
msgstr "A versão do JDK deve ser **exatamente** a mesma"

#. type: Plain text
#. mt: gemini
#: _guides/aot.adoc
#, fuzzy
msgid "AppCDS only caches class metadata, not method profiles or verification results"
msgstr "O AppCDS armazena em cache apenas metadados de classe, não perfis de métodos ou resultados de verificação"

#. type: Plain text
#. mt: gemini
#: _guides/aot.adoc
#, fuzzy
msgid "Training during integration tests is not supported for AppCDS (only build-time generation)"
msgstr "O treinamento durante os testes de integração não é suportado para o AppCDS (apenas geração em tempo de compilação)"

#. type: Plain text
#. mt: gemini
#: _guides/aot.adoc
#, fuzzy
msgid ""
"The legacy `quarkus.package.jar.appcds.enabled` configuration is still supported but deprecated.\n"
"Use `quarkus.package.jar.aot.enabled=true` with `quarkus.package.jar.aot.type=app-cds` instead."
msgstr "A configuração legada `quarkus.package.jar.appcds.enabled` ainda é suportada, mas foi descontinuada.\\nEm vez disso, use `quarkus.package.jar.aot.enabled=true` com `quarkus.package.jar.aot.type=app-cds`."
