#. type: Title ==
#. mt: gemini
#: _guides/cdi-reference.adoc
#, fuzzy, no-wrap
msgid "Monitoring Business Method Invocations and Events"
msgstr "Monitoramento de Invocações de Métodos de Negócio e Eventos"

#. type: Plain text
#. mt: gemini
