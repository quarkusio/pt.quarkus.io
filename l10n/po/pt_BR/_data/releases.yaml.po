#. type: Hash Value: eol_support description
#. mt: deepl
#: _data/releases.yaml:1
#, fuzzy, no-wrap
msgid "HeroDevs provides continued security patches and compliance support for EOL Quarkus versions, bridging the gap while you plan your upgrade.\n"
msgstr "A HeroDevs oferece patches de segurança contínuos e suporte à conformidade para versões do Quarkus que chegaram ao fim da vida útil (EOL), preenchendo essa lacuna enquanto você planeja sua atualização.\n"

#. type: Hash Value: eol_support name
#. mt: deepl
#: _data/releases.yaml:1
#, fuzzy, no-wrap
msgid "HeroDevs Never-Ending Support (NES)"
msgstr "Suporte Infinito da HeroDevs (NES)"

#. type: Hash Value: support_providers herodevs url
#. mt: deepl
#: _data/releases.yaml:1
#, fuzzy, no-wrap
msgid "https://www.herodevs.com/support/quarkus-nes"
msgstr "https://www.herodevs.com/support/quarkus-nes"

#. type: Hash Value: policy eol_description
#. mt: deepl
#: _data/releases.yaml:1
#, fuzzy, no-wrap
msgid "When a Quarkus release reaches End-of-Life, it no longer receives security patches, bug fixes, or community support. Running EOL versions exposes your applications to unpatched vulnerabilities, ecosystem drift, and compliance risks.\n"
msgstr "Quando uma versão do Quarkus atinge o fim do ciclo de vida (EOL), ela deixa de receber correções de segurança, correções de bugs ou suporte da comunidade. A execução de versões EOL expõe suas aplicações a vulnerabilidades não corrigidas, desfasamento do ecossistema e riscos de conformidade.\n"

#. type: Hash Value: policy lts_cadence
#. mt: deepl
#: _data/releases.yaml:1
#, fuzzy, no-wrap
msgid "every 6 months"
msgstr "a cada 6 meses"

#. type: Hash Value: policy lts_description
#. mt: deepl
#: _data/releases.yaml:1
#, fuzzy, no-wrap
msgid "LTS releases receive critical bug fixes and security patches for 12 months from their initial release date.\n"
msgstr "As versões LTS recebem correções de bugs críticos e patches de segurança por um período de 12 meses a partir da data de lançamento inicial.\n"

#. type: Hash Value: policy lts_support_duration
#. mt: deepl
#: _data/releases.yaml:1
#, fuzzy, no-wrap
msgid "12 months"
msgstr "12 meses"

#. type: Hash Value: policy non_lts_support_duration
#. mt: deepl
#: _data/releases.yaml:1
#, fuzzy, no-wrap
msgid "until the next minor release"
msgstr "até a próxima versão secundária"

