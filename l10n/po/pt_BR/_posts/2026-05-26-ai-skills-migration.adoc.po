#. mt: deepl
#: _posts/2026-05-26-ai-skills-migration.adoc
#, fuzzy
msgid "Module"
msgstr "Módulo"

#. type: Table
#. mt: deepl
#: _posts/2026-05-26-ai-skills-migration.adoc
#, fuzzy
msgid "Responsibility"
msgstr "Responsabilidade"

#. type: Table
#. mt: deepl
