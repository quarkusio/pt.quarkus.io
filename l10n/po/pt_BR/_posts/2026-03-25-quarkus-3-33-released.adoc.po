#. type: YAML Front Matter: title
#: _posts/2026-03-25-quarkus-3-33-released.adoc
msgid "Quarkus 3.33 LTS - new LTS version"
msgstr ""

#. type: YAML Front Matter: synopsis
#: _posts/2026-03-25-quarkus-3-33-released.adoc
msgid "We released Quarkus 3.33 LTS, our new LTS version."
msgstr ""

#. type: Plain text
#: _posts/2026-03-25-quarkus-3-33-released.adoc
msgid "It is our pleasure to announce the release of Quarkus 3.33, which is our new LTS (Long Term Support) version."
msgstr ""

#. type: Plain text
#: _posts/2026-03-25-quarkus-3-33-released.adoc
msgid ""
"This version is built on the top of Quarkus 3.32.\n"
"New features landed in https://quarkus.io/blog/quarkus-3-34-released/[Quarkus 3.34], which was also released today."
msgstr ""

#. type: Plain text
#: _posts/2026-03-25-quarkus-3-33-released.adoc
#, fuzzy
msgid "If you want to know more about our LTS policy, the https://quarkus.io/blog/lts-releases/[LTS announcement] is a must read."
msgstr "Se o senhor quiser saber mais sobre nossa política de LTS, o link:https://quarkus.io/blog/lts-releases/[anúncio de LTS] é uma leitura obrigatória."

#. type: Plain text
#: _posts/2026-03-25-quarkus-3-33-released.adoc
#, fuzzy
msgid "LTS releases are supported for 12 months."
msgstr "As versões LTS têm suporte por 12 meses."

#. type: Plain text
#: _posts/2026-03-25-quarkus-3-33-released.adoc
msgid "If you are coming from the previous LTS, Quarkus 3.27 LTS, there are a lot of exciting new features and we recommend reading the following announcements:"
msgstr ""

#. type: Plain text
#: _posts/2026-03-25-quarkus-3-33-released.adoc
msgid "https://quarkus.io/blog/quarkus-3-28-released/[Quarkus 3.28 - More security features, custom Grafana dashboards, support for multiple clients in Liquibase MongoDB, and more]"
msgstr ""

#. type: Plain text
#: _posts/2026-03-25-quarkus-3-33-released.adoc
msgid "https://quarkus.io/blog/quarkus-3-29-released/[Quarkus 3.29 - Multiple cache backends and Qute DAP debugger support]"
msgstr ""

#. type: Plain text
#: _posts/2026-03-25-quarkus-3-33-released.adoc
msgid "https://quarkus.io/blog/quarkus-3-30-released/[Quarkus 3.30 - JsonView on REST Client, Hibernate Validator 9.1, CLI decrypt command, and more]"
msgstr ""

#. type: Plain text
#: _posts/2026-03-25-quarkus-3-33-released.adoc
msgid "https://quarkus.io/blog/quarkus-3-31-released/[Quarkus 3.31 - Full Java 25 support, Quarkus Maven packaging, Panache Next, and more!]"
msgstr ""

#. type: Plain text
#: _posts/2026-03-25-quarkus-3-33-released.adoc
msgid "https://quarkus.io/blog/quarkus-3-32-released/[Quarkus 3.32 - Project Leyden integration, more graceful shutdown, automatic Consul registration and more!]"
msgstr ""

