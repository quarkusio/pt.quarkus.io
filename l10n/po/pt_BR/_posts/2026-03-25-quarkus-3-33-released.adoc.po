msgstr ""

#. type: Plain text
#: _posts/2026-03-25-quarkus-3-33-released.adoc
msgid "https://github.com/quarkusio/quarkus/wiki/Migration-Guide-3.30[Migration guide for 3.30]"
msgstr ""

#. type: Plain text
#: _posts/2026-03-25-quarkus-3-33-released.adoc
msgid "https://github.com/quarkusio/quarkus/wiki/Migration-Guide-3.31[Migration guide for 3.31]"
msgstr ""

#. type: Plain text
#: _posts/2026-03-25-quarkus-3-33-released.adoc
msgid "https://github.com/quarkusio/quarkus/wiki/Migration-Guide-3.32[Migration guide for 3.32]"
msgstr ""

#. type: Plain text
#: _posts/2026-03-25-quarkus-3-33-released.adoc
msgid "https://github.com/quarkusio/quarkus/wiki/Migration-Guide-3.33[Migration guide for 3.33] - this one is empty as 3.33 is the continuation of 3.32"
msgstr ""

#. type: Plain text
#: _posts/2026-03-25-quarkus-3-33-released.adoc
#, fuzzy
msgid ""
"Note that `quarkus update` should handle most of the heavy lifting for you,\n"
"but there are still cases that should be handled manually and we recommend reading these migration guides carefully."
msgstr "Observe que o site `quarkus update` deve cuidar da maior parte do trabalho pesado para o senhor, mas ainda há casos que devem ser tratados manualmente e recomendamos a leitura cuidadosa desses guias de migração."

