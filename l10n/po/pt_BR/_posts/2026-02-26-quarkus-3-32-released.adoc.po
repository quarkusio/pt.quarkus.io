msgstr ""

#. type: Plain text
#: _posts/2026-02-26-quarkus-3-32-released.adoc
msgid "https://github.com/quarkusio/quarkus/pull/52353[#52353] - OIDC: Add basic support for rich authorization requests"
msgstr ""

#. type: Plain text
#: _posts/2026-02-26-quarkus-3-32-released.adoc
msgid "https://github.com/quarkusio/quarkus/pull/52175[#52175] - Make built-in authentication mechanism order customizable"
