msgstr "*Classes de feijão CDI* : `{InterfaceName}_CDI` - Beans CDI injetáveis"

#. type: Plain text
#. mt: deepl
#: _posts/2025-07-15-quickjs4j.adoc
#, fuzzy
msgid "**Factory Classes**: `{InterfaceName}_Factory` - Injectable factory beans"
msgstr "*Classes de fábrica* : `{InterfaceName}_Factory` - Beans de fábrica injetáveis"

#. type: Plain text
#. mt: deepl
#: _posts/2025-07-15-quickjs4j.adoc
#, fuzzy
msgid "**Proxy Classes**: `{InterfaceName}_Proxy` - Generated by quickjs4j"
msgstr "*Classes de proxy* : `{InterfaceName}_Proxy` - Gerado por quickjs4j"

#. type: Plain text
#. mt: deepl
#: _posts/2025-07-15-quickjs4j.adoc
#, fuzzy
msgid "**Context Builtins**: `{ContextName}_Builtins` - JavaScript-accessible Java methods"
msgstr "*Builtins de contexto* : `{ContextName}_Builtins` - métodos Java acessíveis por JavaScript"

#. type: Plain text
#. mt: deepl
#: _posts/2025-07-15-quickjs4j.adoc
#, fuzzy
msgid ""
"This build-time approach ensures minimal runtime overhead while providing full IDE\n"
"support with code completion and type checking."
msgstr "Essa abordagem de tempo de compilação garante uma sobrecarga mínima de tempo de execução e, ao mesmo tempo, oferece suporte total ao IDE com autocompletar de código e verificação de tipos."

