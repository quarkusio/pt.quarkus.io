msgid "Step <span class=\"step-no\">1</span>"
msgstr "Passo <span class=\"step-no\">1</span>"

#. type: Content of: <div><div><div><h3>
#: _includes/get-started-code-steps.html:8
#, fuzzy
msgid "Install via Command Line Interface"
msgstr "Instalar por meio da interface de linha de comando"

#. type: Content of: <div><div><div><p>
#: _includes/get-started-code-steps.html:9
#, fuzzy
msgid "Open your favorite terminal and use JBang to install the Quarkus CLI. You do not need to have Java installed first."
msgstr "Abra seu terminal preferido e use o JBang para instalar a CLI do Quarkus. Não é necessário ter o Java instalado previamente."

#. type: Content of: <div><div><div><h4>
#: _includes/get-started-code-steps.html:10
#, fuzzy
msgid "For Linux, macOS, and Windows (using WSL or bash compatible shell like Cygwin or MinGW)"
msgstr "Para Linux, macOS e Windows (usando o WSL ou um shell compatível com o bash, como o Cygwin ou o MinGW)"

#. type: Content of: <div><div><div><div><div><pre>
#: _includes/get-started-code-steps.html:13
#, fuzzy, no-wrap
msgid ""
"<code>curl -Ls https://sh.jbang.dev | bash -s - trust add https://repo1.maven.org/maven2/io/quarkus/quarkus-cli/\n"
"curl -Ls https://sh.jbang.dev | bash -s - app install --fresh --force quarkus@quarkusio</code>"
msgstr ""
"<code>curl -Ls https://sh.jbang.dev | bash -s - trust add https://repo1.maven.org/maven2/io/quarkus/quarkus-cli/\n"
"curl -Ls https://sh.jbang.dev | bash -s - app install --fresh --force quarkus@quarkusio</code>"

#. type: Content of: <div><div><div><h4>
#: _includes/get-started-code-steps.html:17
#, fuzzy
msgid "For Windows using Powershell"
msgstr "Para o Windows, utilizando o PowerShell"

#. type: Content of: <div><div><div><div><div><pre>
#: _includes/get-started-code-steps.html:20
#, fuzzy, no-wrap
msgid ""
"<code>iex \"& { $(iwr https://ps.jbang.dev) } trust add https://repo1.maven.org/maven2/io/quarkus/quarkus-cli/\"\n"
"iex \"& { $(iwr https://ps.jbang.dev) } app install --fresh --force quarkus@quarkusio\"</code>"
msgstr ""
"<code>iex \"&amp; { $(iwr https://ps.jbang.dev) } trust add https://repo1.maven.org/maven2/io/quarkus/quarkus-cli/\"\n"
"iex \"&amp; { $(iwr https://ps.jbang.dev) } app install --fresh --force quarkus@quarkusio\"</code>"

#. type: Content of: <div><div><div><p>
#: _includes/get-started-code-steps.html:24
#, fuzzy
msgid "If it's your first time to install, you'll need to restart your shell."
msgstr "Se esta for a primeira vez que você estiver instalando, será necessário reiniciar seu shell."

#. type: Content of: <div><div><div><h4>
#: _includes/get-started-code-steps.html:25
#, fuzzy
msgid "Or, you can also install the CLI with SDKMAN!"
msgstr "Ou então, você também pode instalar a CLI com o SDKMAN!"

#. type: Content of: <div><div><div><div><div><pre>
#: _includes/get-started-code-steps.html:28
#, fuzzy, no-wrap
msgid "<code>sdk install quarkus</code>"
msgstr "<code>sdk install quarkus</code>"

#. type: Content of: <div><div><div><h4>
#: _includes/get-started-code-steps.html:31
#, fuzzy
msgid "For more options, such as Homebrew or Chocolatey, see <a href=\"/guides/cli-tooling\">the Quarkus CLI guide</a>."
msgstr "Para conhecer outras opções, como o Homebrew ou o Chocolatey, consulte <a href=\"/guides/cli-tooling\">o guia da CLI do Quarkus</a>."

